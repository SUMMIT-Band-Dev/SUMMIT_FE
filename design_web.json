{
  "designSystem": {
    "colorPalette": {
      "primary": "#B22234",
      "backgroundMain": "#05070A",
      "backgroundSection": "#080A0F",
      "textPrimary": "#FFFFFF",
      "textSecondary": "#A0A0A0",
      "accent": "#FFFFFF",
      "overlay": "rgba(5, 7, 10, 0.75)"
    },
    "typography": {
      "headings": {
        "h1": {
          "fontSize": "64px",
          "fontWeight": "700",
          "fontFamily": "Display/Decorative Sans-Serif",
          "color": "#FFFFFF",
          "textAlign": "center"
        },
        "h2": {
          "fontSize": "32px",
          "fontWeight": "700",
          "letterSpacing": "1px",
          "textTransform": "uppercase"
        }
      },
      "body": {
        "large": {
          "fontSize": "18px",
          "lineHeight": "1.6",
          "color": "#FFFFFF"
        },
        "small": {
          "fontSize": "14px",
          "lineHeight": "1.5",
          "color": "#A0A0A0"
        }
      },
      "stats": {
        "value": {
          "fontSize": "36px",
          "fontWeight": "800",
          "color": "#FFFFFF"
        },
        "label": {
          "fontSize": "12px",
          "textTransform": "capitalize",
          "color": "#FFFFFF"
        }
      }
    },
    "componentStyles": {
      "navigation": {
        "container": {
          "surfaceColor": "transparent",
          "height": "80px",
          "padding": "0 5%"
        },
        "links": {
          "color": "#FFFFFF",
          "fontSize": "13px",
          "textTransform": "uppercase",
          "hoverState": {
            "color": "#B22234"
          }
        }
      },
      "heroSection": {
        "surface": {
          "backgroundImage": "url('concert-crowd.jpg')",
          "overlay": "linear-gradient(180deg, rgba(5,7,10,0.4) 0%, #05070A 100%)",
          "padding": "120px 0"
        }
      },
      "actionControls": {
        "primaryButton": {
          "surfaceColor": "#B22234",
          "textColor": "#FFFFFF",
          "borderRadius": "4px",
          "padding": "12px 24px",
          "fontSize": "14px",
          "textTransform": "uppercase",
          "interactionStates": {
            "hoverSurface": "#8B1A29"
          }
        },
        "videoTrigger": {
          "size": "60px",
          "border": "2px solid #FFFFFF",
          "borderRadius": "50%",
          "iconColor": "#FFFFFF",
          "background": "rgba(255, 255, 255, 0.1)"
        }
      },
      "mediaCards": {
        "imageWrapper": {
          "borderRadius": "8px",
          "overflow": "hidden",
          "border": "none"
        },
        "videoThumbnail": {
          "aspectRatio": "16:9",
          "elevationShadow": "0 10px 30px rgba(0,0,0,0.5)"
        }
      },
      "footer": {
        "surface": {
          "backgroundColor": "#05070A",
          "borderTop": "1px solid rgba(255,255,255,0.05)",
          "padding": "60px 0 20px"
        },
        "socialIcons": {
          "size": "32px",
          "color": "#FFFFFF",
          "background": "rgba(255,255,255,0.1)",
          "borderRadius": "50%",
          "spacing": "12px"
        }
      }
    },
    "layout": {
      "maxWidth": "1200px",
      "gridColumns": 12,
      "sectionSpacing": "100px",
      "contentPadding": "20px"
    }
  }
}
